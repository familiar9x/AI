# === MariaDB (external) ===
DB_HOST=10.0.0.10
DB_PORT=3306
DB_USER=finance_ro
DB_PASSWORD=change_me
DB_NAME=finance_db

# Optional: specify default schema if needed
DB_SCHEMA=

# === API ===
API_HOST=0.0.0.0
API_PORT=8000

# === Dashboard ===
DASHBOARD_API_BASE=http://nginx/api

# === LLM Provider ===
# options: none | ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# === Config paths (inside containers) ===
SCHEMA_MAP_PATH=/app/config/schema_map.yaml
NEWS_SOURCES_PATH=/app/config/news_sources.txt

# === Vector DB & Cache ===
QDRANT_COLLECTION_NEWS=news_items
EMBED_PROVIDER=ollama
